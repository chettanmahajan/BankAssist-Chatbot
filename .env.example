# ============================================
# Banking Chatbot — environment configuration
# Copy to .env and fill real values. NEVER commit .env.
# ============================================

# --- LLM (Groq) ---
GROQ_API_KEY=gsk_replace_with_your_key
GROQ_MODEL=llama-3.3-70b-versatile

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vector store ---
VECTORSTORE_DIR=./Faiss_db
DATA_DIR=./data

# --- Redis cache ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TTL_SECONDS=3600

# --- Retrieval ---
RETRIEVAL_K=5
RETRIEVAL_FETCH_K=15
RETRIEVAL_LAMBDA=0.6
LOW_SCORE_THRESHOLD=0.35

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- Frontend ---
API_URL=http://localhost:8000
REQUEST_TIMEOUT_SECONDS=60
